# Copy this file to .env and fill in your own values. .env is gitignored.

OPENAI_API_KEY=sk-...

# Path to the PDF knowledge base the bot is allowed to answer from.
KNOWLEDGE_BASE_FILE=knowledge_base/affiliate_program_faq.pdf

# Left empty on first run — assistant_manager.py fills this in automatically
# once the vector store is created, so the same one is reused afterwards.
VECTOR_STORE_ID=

VECTOR_STORE_NAME=affiliate-support-kb
ASSISTANT_NAME=Affiliate Support Bot
ASSISTANT_MODEL=gpt-5.4-mini
